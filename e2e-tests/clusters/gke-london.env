# GKE London Demo
GRAPH_OLAP_API_URL=https://control-plane-graph-olap-platform.hsbc-12636856-udlhk-dev.dev.gcp.cloud.hk.hsbc
GRAPH_OLAP_IN_CLUSTER_MODE=false
GRAPH_OLAP_SKIP_HEALTH_CHECK=false
GRAPH_OLAP_NAMESPACE=hsbc-graph

# Pre-flight validation
VALIDATE_DEPLOYMENT=false     # Skip - external cluster
CLEANUP_VIA_KUBECTL=false     # API-only cleanup

# kubectl context (auto-switched by run-tests.sh)
KUBE_CONTEXT=gke_hsbc-graph_europe-west2-a_hsbc-graph-london

# System ops user for persona provisioning (ADR-126)
SYSTEM_OPS_USER=ops_dave@e2e.local

# Starburst Galaxy use case ID (ADR-102/115)
# Sent as X-Use-Case-Id header → stored as starburst_role on export jobs → SET ROLE in Starburst
GRAPH_OLAP_USE_CASE_ID=e2e_test_role

# Starburst Galaxy cluster URL (for wake_starburst() in notebooks)
STARBURST_TRINO_URL=https://hsbcgraph-test.trino.galaxy.starburst.io

# Starburst Galaxy service account (ADR-119)
# STARBURST_PASSWORD is loaded from K8s secret in run-tests.sh
STARBURST_USER=graph-olap-e2e@hsbcgraph.galaxy.starburst.io

# Persona JWT tokens (30-day expiry)
# Generate with: ./tools/local-dev/scripts/generate-e2e-tokens.sh
# Then: source .env.e2e-tokens
# Tokens contain identity (email + role) in custom claims
# GRAPH_OLAP_API_KEY_ANALYST_ALICE=<jwt>
# GRAPH_OLAP_API_KEY_ANALYST_BOB=<jwt>
# GRAPH_OLAP_API_KEY_ADMIN_CAROL=<jwt>
# GRAPH_OLAP_API_KEY_OPS_DAVE=<jwt>
