# Local OrbStack Kubernetes
# All local ingresses use host: localhost for consistent nginx server routing
GRAPH_OLAP_API_URL=http://localhost:30081
GRAPH_OLAP_IN_CLUSTER_MODE=false
GRAPH_OLAP_NAMESPACE=graph-olap-local

# kubectl context (auto-switched by run-tests.sh)
KUBE_CONTEXT=orbstack

# Pre-flight validation
VALIDATE_DEPLOYMENT=true      # Run validate-test-freshness.sh
CLEANUP_VIA_KUBECTL=true      # Can use kubectl for cleanup

# Zero-credential local development (ADR-111)
# No environment variables needed for local development:
#   - No STARBURST_USER / STARBURST_PASSWORD (emulator replaces Galaxy)
#   - No GCP SA key (Parquet stored locally, not GCS)
#   - No JWT tokens (X-Username header identity per ADR-104)
#
# Persona usernames match seeded users in the database.
# These are resolved by conftest.py via TestPersona.name fallback.
# Users are auto-seeded by deploy.sh when emulator is enabled.
